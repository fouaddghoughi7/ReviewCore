{
    "name": "reviewcore/reviewcore",
    "description": "ReviewCore Enterprise Review Platform",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ReviewCore\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/core",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "reviewcore/core": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}